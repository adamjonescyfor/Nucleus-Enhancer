{
    "manifest_version": 3,
    "name": "CYFOR Nucleus Enhancer",
    "version": "1.0.0",
    "description": "Right-click Date/Time, Record Navigation, Top-Aligned Notes Formatting, Context-Aware Table Column Reordering, Template Injection (incl. Forensic Strategy), Right-Click Template Menu, and more.",
    "key": "",

    "permissions": [
        "activeTab",
        "storage",
        "downloads",
        "scripting",
        "identity",
        "alarms",
        "notifications"
    ],

    "host_permissions": [
        "https://*.lightning.force.com/*",
        "https://*.my.salesforce.com/*",
        "https://*.file.force.com/*",
        "https://*.content.force.com/*",
        "https://*.documentforce.com/*",
        "https://*.salesforce.com/*",
        "https://*.workers.dev/*"
    ],

    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },

    "action": {
        "default_popup": "popup/popup.html",
        "default_title": "CYFOR Nucleus Enhancer",
        "default_icon": {
            "16": "icons/icon16.png",
            "32": "icons/icon32.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },

    "options_page": "manager/manager.html",

    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'none'; worker-src 'self'"
    },

    "background": {
        "service_worker": "background.js"
    },

    "commands": {
        "undo-insertion": {
            "suggested_key": {
                "default": "Alt+Z",
                "mac": "Alt+Z"
            },
            "description": "Undo last template insertion"
        },
        "open-template-menu": {
            "suggested_key": {
                "default": "Alt+T",
                "mac": "Alt+T"
            },
            "description": "Open template dropdown in active editor"
        }
    },

    "content_scripts": [
        {
            "matches": ["https://*.lightning.force.com/*"],
            "run_at": "document_idle",
            "js": [
                "content/theme-apply.js",
                "content/utils.js",
                "content/debug.js",
                "content/config.js",
                "content/toast.js",
                "content/undo.js",
                "content/usage.js",
                "content/builtin-templates.js",
                "lib/sanitize-html.js",
                "content/editor.js",
                "content/datetime.js",
                "content/navigation.js",
                "content/columns.js",
                "content/notes-data.js",
                "content/notes.js",
                "content/templates.js",
                "content/context-menu.js",
                "content/downloads.js",
                "content/case-alias.js",
                "content/main.js"
            ],
            "css": [
                "styles/base.css",
                "styles/navigation.css",
                "styles/notes.css",
                "styles/templates.css",
                "styles/toast.css",
                "styles/context-menu.css",
                "styles/case-report.css"
            ]
        }
    ],

    "web_accessible_resources": [
        {
            "resources": ["report/cyfor-logo.png"],
            "matches": ["https://*.lightning.force.com/*"]
        }
    ]
}
